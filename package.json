{
  "name": "mongoshift",
  "version": "0.1.0",
  "description": "MongoDB migration tool with dry-run, file-hash detection, and stored logs",
  "keywords": [
    "cli",
    "esm",
    "migration",
    "migrations",
    "mongodb",
    "typescript"
  ],
  "homepage": "https://github.com/vmaerten/mongoshift#readme",
  "bugs": {
    "url": "https://github.com/vmaerten/mongoshift/issues"
  },
  "license": "MIT",
  "author": "Valentin Maerten <maerten.valentin@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vmaerten/mongoshift.git"
  },
  "bin": {
    "mongoshift": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "test": "vitest run --exclude test/integration.test.ts",
    "test:watch": "vitest --exclude test/integration.test.ts",
    "test:integration": "vitest run test/integration.test.ts",
    "test:all": "vitest run"
  },
  "dependencies": {
    "cli-table3": "^0.6.5",
    "commander": "^14.0.0",
    "dayjs": "^1.11.20"
  },
  "devDependencies": {
    "@types/node": "^24.12.2",
    "mongodb": "^6.10.0",
    "mongodb-memory-server": "^10.1.0",
    "oxfmt": "^0.43.0",
    "oxlint": "^1.58.0",
    "tsdown": "^0.21.7",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "peerDependencies": {
    "mongodb": "^6.0.0"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "packageManager": "pnpm@10.33.0"
}
