{
  "name": "mongo-migration",
  "version": "0.1.0",
  "description": "MongoDB migration tool with dry-run, file-hash detection, and stored logs",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "mongo-migration": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc && chmod +x dist/cli.js",
    "test": "vitest run --exclude test/integration.test.ts",
    "test:watch": "vitest --exclude test/integration.test.ts",
    "test:integration": "vitest run test/integration.test.ts",
    "test:all": "vitest run"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "cli-table3": "^0.6.5",
    "commander": "^14.0.0"
  },
  "peerDependencies": {
    "mongodb": "^6.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "mongodb": "^6.10.0",
    "mongodb-memory-server": "^10.1.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
